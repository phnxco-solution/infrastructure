# Traefik Dashboard
# Domain for accessing the Traefik dashboard
TRAEFIK_DASHBOARD_DOMAIN=traefik.phnx-solution.com

# Generate with: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$...hashed-password...

# MySQL
MYSQL_ROOT_PASSWORD=your-secure-root-password

# Redis
REDIS_PASSWORD=your-secure-redis-password

# Uptime Kuma
UPTIME_KUMA_DOMAIN=status.phnx-solution.com
